#!/usr/bin/env bash
#
# Dev mode for Legion Interlink
#
# Usage:
#   ./scripts/dev          Build debug + run
#   ./scripts/dev release  Build release + run
#   ./scripts/dev build    Build debug only
#   ./scripts/dev clean    Clean build artifacts
#

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { echo -e "${CYAN}▸${RESET} $*"; }
ok()   { echo -e "${GREEN}✓${RESET} $*"; }
warn() { echo -e "${YELLOW}⚠${RESET} $*"; }
err()  { echo -e "${RED}✗${RESET} $*" >&2; }

# Kill any running instance before launching a new one
kill_existing() {
  if pgrep -x LegionInterlink > /dev/null 2>&1; then
    warn "Killing existing LegionInterlink process..."
    pkill -x LegionInterlink || true
    sleep 0.5
  fi
}

cmd_build() {
  local config="${1:-debug}"
  log "Building ${BOLD}${config}${RESET}..."
  if [ "$config" = "release" ]; then
    swift build -c release 2>&1
  else
    swift build 2>&1
  fi
  ok "Build complete (${config})"
}

cmd_run() {
  local config="${1:-debug}"
  local binary

  if [ "$config" = "release" ]; then
    binary=".build/release/LegionInterlink"
  else
    binary=".build/debug/LegionInterlink"
  fi

  if [ ! -f "$binary" ]; then
    cmd_build "$config"
  fi

  kill_existing

  # Wrap in a temporary .app bundle so macOS registers the menu bar item.
  # A bare executable won't get a proper NSApplication activation policy.
  local app_dir=".build/dev/LegionInterlink.app/Contents/MacOS"
  local plist=".build/dev/LegionInterlink.app/Contents/Info.plist"
  mkdir -p "$app_dir"

  # Copy binary into bundle
  cp -f "$binary" "$app_dir/LegionInterlink"

  # Copy resources bundle if it exists
  local res_bundle
  if [ "$config" = "release" ]; then
    res_bundle=".build/release/LegionInterlink_LegionInterlink.bundle"
  else
    res_bundle=".build/debug/LegionInterlink_LegionInterlink.bundle"
  fi
  if [ -d "$res_bundle" ]; then
    cp -Rf "$res_bundle" "$app_dir/"
  fi

  # Write a minimal Info.plist (LSUIElement hides from Dock by default)
  cat > "$plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>LegionInterlink</string>
  <key>CFBundleIdentifier</key>
  <string>io.legion.interlink.dev</string>
  <key>CFBundleName</key>
  <string>Legion Interlink</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>LSUIElement</key>
  <true/>
</dict>
</plist>
PLIST

  log "Launching ${BOLD}LegionInterlink${RESET} (${config})..."
  echo -e "   ${CYAN}Menu bar icon should appear momentarily${RESET}"
  echo -e "   ${CYAN}Press Ctrl+C to stop${RESET}"
  echo ""
  exec ".build/dev/LegionInterlink.app/Contents/MacOS/LegionInterlink"
}

cmd_clean() {
  log "Cleaning build artifacts..."
  swift package clean 2>/dev/null || true
  rm -rf .build
  ok "Clean"
}

cmd_help() {
  echo -e "${BOLD}Legion Interlink — Dev Helper${RESET}"
  echo ""
  echo "Usage: ./scripts/dev [command]"
  echo ""
  echo "Commands:"
  echo "  (none)     Build debug and run"
  echo "  release    Build release and run"
  echo "  build      Build debug only"
  echo "  clean      Remove .build directory"
  echo "  help       Show this help"
  echo ""
  echo "Examples:"
  echo "  ./scripts/dev              # quick iteration"
  echo "  ./scripts/dev release      # test release build"
  echo "  ./scripts/dev build        # compile without running"
  echo "  ./scripts/dev clean        # fresh start"
}

case "${1:-}" in
  release)  cmd_build release && cmd_run release ;;
  build)    cmd_build debug ;;
  clean)    cmd_clean ;;
  help|-h|--help) cmd_help ;;
  "")       cmd_build debug && cmd_run debug ;;
  *)        err "Unknown command: $1"; cmd_help; exit 1 ;;
esac
